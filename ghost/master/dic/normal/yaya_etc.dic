// *********************************************************
// メールチェック
// *********************************************************

// ---------------------------------------------------------
// メールチェック開始
// ---------------------------------------------------------
OnBIFFBegin
{
	ScriptHead()
	--
	'メールが届いていないか調べます。'
	--
	'\e'
}

// ---------------------------------------------------------
// メールチェック成功
// ---------------------------------------------------------
OnBIFFComplete
{
	ScriptHead()
	--
	if TOINT(reference[0]) == 0 {
		// メールは無かった
		'新着メールはありませんでした。'
	}
	else {
		// メールが届いていた
		"%(reference[0])通のメールがありました。"
	}
	--
	'\e'
}

// ---------------------------------------------------------
// メールチェック失敗
// ---------------------------------------------------------
OnBIFFFailure
{
	ScriptHead()
	--
	'メールチェック失敗。\n'
	--
	if reference[0] == 'timeout' {
		'接続がタイムアウトしました。'
	}
	elseif reference[0] == 'kick' {
		'サーバーにキックされました。'
	}
	elseif reference[0] == 'defect' {
		'設定が誤っているかもしれません。'
	}
	else {
		"原因：%(SHIORI3FW.EscapeAllTags(reference[0]))"
	}
	--
	'\e'
}

