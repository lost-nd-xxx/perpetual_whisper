// *********************************************************
// ヘッドラインセンス
// *********************************************************

// ---------------------------------------------------------
// ヘッドラインセンス開始
// ---------------------------------------------------------
OnHeadlinesenseBegin
{
	_escaped_name = SHIORI3FW.EscapeAllTags(reference[0])

	ScriptHead()
	--
	"%(_escaped_name)のヘッドラインを取得中です。"
	--
	'\e'
}

// ---------------------------------------------------------
// ヘッドライン読み上げ
// ---------------------------------------------------------
OnHeadlinesense.OnFind
{
	ScriptHead()
	--
	// ヘッドライン題名
	_escaped_name = SHIORI3FW.EscapeAllTags(reference[0])
	"%(_escaped_name)"
	--
	// ヘッドライン本体
	"\n[150]%(reference[3])\n[150]"
	--
	// 選択肢
	if reference[2] == 'First' || reference[2] == 'Next' {
		// 次のページがある場合
		AYATEMPLATE.MenuItem('次のページ', '')
		--
		AYATEMPLATE.MenuItem('サイトへ', reference[1])
		--
		AYATEMPLATE.MenuItem('やめる', 'script:\e', 150)
	}
	else {
		// 次のページがない場合
		AYATEMPLATE.MenuItem('サイトへ', reference[1])
		--
		AYATEMPLATE.MenuItem('やめる', 'script:\e', 150)
	}
}

// ---------------------------------------------------------
// ヘッドライン更新が無かった
// ---------------------------------------------------------
OnHeadlinesenseComplete
{
	_escaped_name = SHIORI3FW.EscapeAllTags(reference[0])

	ScriptHead()
	--
	"%(_escaped_name)の更新はないようです。"
	--
	'\e'
}

// ---------------------------------------------------------
// ヘッドラインセンス失敗
// ---------------------------------------------------------
OnHeadlinesenseFailure
{
	ScriptHead()
	--
	'ヘッドラインセンスに失敗しました。\n理由：'
	--
	if reference[0] == "can't download" {
		'ダウンロード失敗。'
	}
	elseif reference[0] == "can't analyze" {
		'ヘッドライン解析失敗。'
	}
	else {
		SHIORI3FW.EscapeAllTags(reference[0])
	}
	--
	'\e'
}

